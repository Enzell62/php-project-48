{
    "name": "hexlet/code",
    "description": "Compares two configuration files and shows a difference.",
    "license": "MIT",
    "authors": [
        {
            "name": "Enzell",
            "email": "roman.knyazev.dev@gmail.com"
        }
    ],
    "require": {
        "docopt/docopt": "^1.0",
        "symfony/yaml": "^5.4",
        "funct/funct": "^1.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^3.6"
    },
    "autoload": {
        "psr-4": {
            "Differ\\": "src/"
        },
        "files": [
            "src/genDiff.php",
            "src/Formatter/Stylish.php",
            "src/Formatter/Plain.php",
            "src/Formatter/Json.php",
            "src/Formatter/Formatter.php",
            "src/Parser/Parser.php",
            "src/Differ/Differ.php"
        ]
    },
    "bin": [
        "bin/gendiff"
    ]
}
